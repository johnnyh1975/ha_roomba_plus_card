{
  "name": "roomba-plus-card",
  "version": "2.0.2",
  "description": "HACS Lovelace card for the roomba_plus Home Assistant integration",
  "keywords": [
    "home-assistant",
    "lovelace",
    "roomba",
    "irobot",
    "hacs"
  ],
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/roomba-plus-card.ts --bundle --outfile=dist/roomba-plus-card.js --format=esm --target=es2020 --minify",
    "dev": "esbuild src/roomba-plus-card.ts --bundle --outfile=dist/roomba-plus-card.js --format=esm --target=es2020 --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/johnnyh1975/ha_roomba_plus_card.git"
  }
}