{
  "domain": "roomba_plus",
  "name": "Roomba+",
  "version": "2.0.0",
  "codeowners": [
    "@johnnyh1975"
  ],
  "config_flow": true,
  "dependencies": [],
  "after_dependencies": [
    "dhcp",
    "zeroconf"
  ],
  "documentation": "https://github.com/johnnyh1975/ha_roomba_plus",
  "issue_tracker": "https://github.com/johnnyh1975/ha_roomba_plus/issues",
  "integration_type": "device",
  "iot_class": "local_push",
  "loggers": [
    "paho_mqtt",
    "roombapy"
  ],
  "services": "services.yaml",
  "requirements": [
    "roombapy==1.9.1"
  ],
  "dhcp": [
    {
      "hostname": "irobot-*",
      "macaddress": "501479*"
    },
    {
      "hostname": "roomba-*",
      "macaddress": "80A589*"
    },
    {
      "hostname": "roomba-*",
      "macaddress": "DCF505*"
    },
    {
      "hostname": "roomba-*",
      "macaddress": "204EF6*"
    }
  ],
  "zeroconf": [
    {
      "name": "irobot-*",
      "type": "_amzn-alexa._tcp.local."
    },
    {
      "name": "roomba-*",
      "type": "_amzn-alexa._tcp.local."
    }
  ],
  "is_built_in": false,
  "overwrites_built_in": false
}